            <ImageView fitHeight="20" fitWidth="20" layoutX="24.0" layoutY="240.0" preserveRatio="true">
               <image>
                  <Image url="@background/user.png" />
               </image>
            </ImageView>
            <ImageView fitHeight="20" fitWidth="20" layoutX="24.0" layoutY="296.0" preserveRatio="true">
