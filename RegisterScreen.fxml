            <Button fx:id="loginButton" layoutX="72.0" layoutY="306.0" prefWidth="200.0" styleClass="button-left" text="SIGN UP" />
            <Label layoutX="49.0" layoutY="173.0" prefHeight="51.0" prefWidth="244.0" styleClass="infoText" text="You can create your personal " />
            <Label layoutX="71.0" layoutY="215.0" prefHeight="51.0" prefWidth="210.0" styleClass="infoText" text="account clicking on button " />
        </children>
    </AnchorPane>

   
</AnchorPane>
