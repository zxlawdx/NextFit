<AnchorPane minHeight="400" minWidth="600" prefHeight="600" prefWidth="800" stylesheets="@RegisterScreen.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="system.RegisterScreen">

       <AnchorPane layoutX="42.0" layoutY="14.0" prefHeight="568.0" prefWidth="340.0" styleClass="leftbar">
